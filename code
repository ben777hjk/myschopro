<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Rust-like 3D Prototype (Better Oxum's + Better Colliders + Better Loot)</title>
<style>
  body { margin:0; overflow:hidden; background:#000; font-family:sans-serif; color:white; user-select:none; }
  #statusHud {
    position:fixed; right:18px; bottom:18px; display:flex; flex-direction:column; gap:8px;
    z-index:10; min-width:170px;
  }
  .hudStat {
    display:flex; align-items:center; justify-content:space-between;
    padding:8px 12px; border-radius:999px; font-size:12px; font-weight:700;
    color:#101010; background:rgba(255,255,255,0.9);
    border:1px solid rgba(255,255,255,0.22);
  }
  .hudBlue { background:#59b8ff; }
  .hudGreen { background:#70d67e; }
  .hudOrange { background:#ffaf52; }
  #crosshair {
    position:fixed; top:50%; left:50%; width:10px; height:10px;
    margin-left:-5px; margin-top:-5px; border:2px solid white;
    border-radius:50%; pointer-events:none; z-index:5;
  }
  #hotbar {
    position:fixed; bottom:20px; left:50%; transform:translateX(-50%);
    display:flex; gap:6px; z-index:10;
  }
  .slot, .lootSlot {
    width:56px; height:56px; border:2px solid rgba(255,255,255,0.28); background:rgba(16,16,16,0.75);
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    font-size:11px; box-sizing:border-box; position:relative; border-radius:10px;
    backdrop-filter:blur(4px);
  }
  .slot.selected {
    border-color:#ffd700;
    box-shadow:0 0 0 1px rgba(255,215,0,0.35);
  }
  .slot .count, .lootSlot .count {
    position:absolute; bottom:2px; right:4px; font-size:10px;
  }
  .slot .icon, .lootSlot .icon {
    font-size:22px; line-height:1; margin-bottom:4px;
    text-shadow:0 1px 3px rgba(0,0,0,0.4);
  }
  .slot .name, .lootSlot .name {
    font-size:9px; text-align:center; line-height:1.1; padding:0 3px;
    color:#f0f0f0;
  }
  #inventoryPanel {
    position:fixed; top:50%; left:50%; transform:translate(-50%,-50%);
    width:430px; min-height:330px; background:rgba(10,10,10,0.92); border:1px solid rgba(255,255,255,0.18);
    display:none; flex-direction:column; padding:10px; box-sizing:border-box; z-index:20;
    border-radius:12px; backdrop-filter:blur(6px);
  }
  #inventoryGrid {
    display:grid; grid-template-columns:repeat(5,1fr); grid-gap:6px; margin-top:10px;
  }
  #inventoryPanel h3, #lootPanel h3 {
    margin:0; font-size:14px; margin-bottom:6px;
  }
  #lootPanel {
    position:fixed; top:50%; left:50%; transform:translate(-50%,-50%);
    width:320px; min-height:330px; background:rgba(10,10,10,0.92); border:1px solid rgba(255,255,255,0.18);
    display:none; flex-direction:column; padding:10px; box-sizing:border-box; z-index:25;
    border-radius:12px; backdrop-filter:blur(6px);
  }
  #lootGrid {
    display:grid; grid-template-columns:repeat(4,1fr); grid-gap:6px; margin-top:10px;
  }
  #dragItem {
    position:fixed; pointer-events:none; z-index:30;
    padding:4px 6px; background:rgba(0,0,0,0.8); border:1px solid #fff;
    font-size:11px; display:none;
  }
  .panelTabs {
    display:flex; gap:8px; margin-bottom:10px;
  }
  .panelTab {
    padding:8px 12px; border-radius:8px; border:1px solid rgba(255,255,255,0.16);
    background:rgba(255,255,255,0.06); color:#ddd; cursor:pointer; font-size:12px;
  }
  .panelTab.active {
    background:#b48336; color:#111; border-color:#d9b26a; font-weight:700;
  }
  .panelPage {
    display:none;
  }
  .panelPage.active {
    display:block;
  }
  #craftingGrid {
    display:grid; grid-template-columns:repeat(2,1fr); gap:8px; margin-top:8px;
  }
  .recipeCard {
    padding:10px; border-radius:10px; border:1px solid rgba(255,255,255,0.12);
    background:rgba(255,255,255,0.05); cursor:pointer;
  }
  .recipeCard.disabled {
    opacity:0.45;
    cursor:not-allowed;
  }
  .recipeTitle {
    font-size:13px; font-weight:700; margin-bottom:4px;
  }
  .recipeMeta {
    font-size:11px; color:#d0d0d0;
  }
  #craftQueue {
    margin-top:10px; padding:10px; border-radius:10px;
    background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.12);
  }
  #craftProgressBar {
    width:100%; height:10px; border-radius:999px; overflow:hidden;
    background:rgba(255,255,255,0.08); margin-top:8px;
  }
  #craftProgressFill {
    width:0%; height:100%; background:linear-gradient(90deg,#b48336,#e3c484);
  }
  #buildMenu {
    position:fixed; bottom:92px; left:50%; transform:translateX(-50%);
    display:none; gap:10px; padding:12px; border-radius:12px;
    background:rgba(10,10,10,0.92); border:1px solid rgba(255,255,255,0.16);
    z-index:18; backdrop-filter:blur(6px);
  }
  .buildCard {
    width:140px; padding:10px; border-radius:10px; background:rgba(255,255,255,0.05);
    border:1px solid rgba(255,255,255,0.12); cursor:pointer;
  }
  .buildCard.active {
    border-color:#d9b26a; background:rgba(180,131,54,0.18);
  }
  #errorOverlay {
    position:fixed; left:16px; bottom:16px; max-width:420px; display:none;
    padding:10px 12px; background:rgba(120,20,20,0.92); color:#fff;
    border:1px solid rgba(255,255,255,0.18); border-radius:10px; z-index:50;
    font-size:12px; white-space:pre-wrap;
  }
  #mapPanel {
    position:fixed; inset:32px; display:none; z-index:40;
    background:rgba(10,14,20,0.92); border:1px solid rgba(255,255,255,0.18);
    border-radius:14px; padding:18px; box-sizing:border-box;
  }
  #mapPanel h3 {
    margin:0 0 12px 0; font-size:16px;
  }
  #mapCanvas {
    width:100%; height:calc(100% - 28px); display:block;
    border-radius:10px; background:#1b2633;
  }
  #radialMenu {
    position:fixed; width:320px; height:320px; display:none; z-index:45;
    transform:translate(-50%,-50%);
    border-radius:50%; pointer-events:none;
  }
  .radialCenter {
    position:absolute; left:50%; top:50%; width:150px; height:150px;
    transform:translate(-50%,-50%); border-radius:50%;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    background:rgba(18,17,14,0.9); color:#f3ece1; text-align:center;
    border:10px solid rgba(242,236,225,0.9); box-sizing:border-box;
    box-shadow:0 12px 30px rgba(0,0,0,0.28);
  }
  .radialCenterTitle {
    font-size:26px; font-weight:800; line-height:1;
  }
  .radialCenterMeta {
    margin-top:8px; font-size:12px; color:rgba(243,236,225,0.75);
  }
  .radialOption {
    position:absolute; width:88px; height:88px; border-radius:50%;
    display:flex; align-items:center; justify-content:center; text-align:center;
    background:rgba(244,237,227,0.94); color:#b53f28; border:none;
    font-size:12px; font-weight:800; line-height:1.15; pointer-events:auto; cursor:pointer;
    box-shadow:0 10px 24px rgba(0,0,0,0.18);
  }
  .radialOption:hover {
    background:#d74a2f; color:#fff;
  }
  #buildHint {
    position:fixed; left:50%; bottom:88px; transform:translateX(-50%);
    display:none; padding:8px 14px; border-radius:999px; z-index:16;
    background:rgba(7,12,18,0.88); color:#dbeaff; border:1px solid rgba(112,183,255,0.3);
    font-size:12px; font-weight:700; letter-spacing:0.03em;
  }
</style>
</head>
<body>

<div id="statusHud">
  <div class="hudStat hudBlue">Health <span id="health">100</span></div>
  <div class="hudStat hudGreen">Hunger <span id="hunger">100</span></div>
  <div class="hudStat hudOrange">Water <span id="water">100</span></div>
</div>

<div id="crosshair"></div>
<div id="hotbar"></div>

<div id="inventoryPanel">
  <div class="panelTabs">
    <button id="inventoryTabBtn" class="panelTab active">Inventory</button>
    <button id="craftingTabBtn" class="panelTab">Crafting</button>
  </div>
  <div id="inventoryPage" class="panelPage active">
    <h3>Inventory (Stacks of 100)</h3>
    <div id="inventoryGrid"></div>
  </div>
  <div id="craftingPage" class="panelPage">
    <h3>Crafting</h3>
    <div id="craftingGrid"></div>
    <div id="craftQueue">
      <div id="craftQueueText">No item crafting</div>
      <div id="craftProgressBar"><div id="craftProgressFill"></div></div>
    </div>
  </div>
</div>

<div id="lootPanel">
  <h3>Loot</h3>
  <div id="lootGrid"></div>
</div>

<div id="buildMenu"></div>
<div id="buildHint"></div>

<div id="dragItem"></div>
<div id="errorOverlay"></div>
<div id="mapPanel">
  <h3>Island Map</h3>
  <canvas id="mapCanvas" width="900" height="600"></canvas>
</div>
<div id="radialMenu"></div>

<script src="https://unpkg.com/three@0.160.0/build/three.min.js"></script>
<script>
/* ---------------------------------------------------------
   BASIC SETUP
--------------------------------------------------------- */
const renderer = new THREE.WebGLRenderer({ antialias:true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.1));
renderer.setSize(innerWidth, innerHeight);
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
document.body.appendChild(renderer.domElement);
const errorOverlay = document.getElementById("errorOverlay");
const mapPanel = document.getElementById("mapPanel");
const mapCanvas = document.getElementById("mapCanvas");
const radialMenu = document.getElementById("radialMenu");

function showErrorOverlay(err) {
  if (!errorOverlay) return;
  errorOverlay.style.display = "block";
  errorOverlay.textContent = "Game error:\n" + (err && err.message ? err.message : String(err));
}

window.addEventListener("error", e => {
  showErrorOverlay(e.error || e.message);
});

const scene = new THREE.Scene();
scene.background = new THREE.Color(0x87ceeb);
scene.fog = new THREE.Fog(0x87ceeb, 80, 260);
const daySkyColor = new THREE.Color(0x87ceeb);
const nightSkyColor = new THREE.Color(0x09111f);

const camera = new THREE.PerspectiveCamera(75, innerWidth/innerHeight, 0.1, 1000);
scene.add(camera);
const WORLD_RADIUS = 200;
const TERRAIN_RADIUS = 160;
const BEACH_INNER = 132;
const WATER_INNER = 150;

function randRange(min, max) {
  return min + Math.random() * (max - min);
}

function getBiomeAtFromLayout(layout, x, z) {
  const edge = Math.max(Math.abs(x), Math.abs(z));
  if (edge > WATER_INNER) return "water";
  if (edge > BEACH_INNER) return "beach";

  const snowA =
    ((x - layout.snowA.x) * (x - layout.snowA.x)) / (layout.snowA.rx * layout.snowA.rx) +
    ((z - layout.snowA.z) * (z - layout.snowA.z)) / (layout.snowA.rz * layout.snowA.rz) +
    Math.sin((x + layout.noiseX) * 0.035) * 0.12 +
    Math.cos((z + layout.noiseZ) * 0.028) * 0.08;
  const snowB =
    ((x - layout.snowB.x) * (x - layout.snowB.x)) / (layout.snowB.rx * layout.snowB.rx) +
    ((z - layout.snowB.z) * (z - layout.snowB.z)) / (layout.snowB.rz * layout.snowB.rz) +
    Math.sin((x + z + layout.noiseMix) * 0.03) * 0.08;
  if (snowA < 1 || snowB < 1) return "snow";

  const desertA =
    ((x - layout.desertA.x) * (x - layout.desertA.x)) / (layout.desertA.rx * layout.desertA.rx) +
    ((z - layout.desertA.z) * (z - layout.desertA.z)) / (layout.desertA.rz * layout.desertA.rz) +
    Math.cos((z - layout.noiseZ) * 0.03) * 0.1 +
    Math.sin((x + layout.noiseX) * 0.026) * 0.08;
  const desertB =
    ((x - layout.desertB.x) * (x - layout.desertB.x)) / (layout.desertB.rx * layout.desertB.rx) +
    ((z - layout.desertB.z) * (z - layout.desertB.z)) / (layout.desertB.rz * layout.desertB.rz) +
    Math.sin((x - z + layout.noiseMix) * 0.028) * 0.07;
  if (desertA < 1 || desertB < 1) return "desert";

  return "grass";
}

function findRandomWorldSpot(layout, biome, options = {}) {
  const minOxumsDist = options.minOxumsDist ?? 0;
  const maxEdge = options.maxEdge ?? (BEACH_INNER - 8);
  for (let attempt=0; attempt<250; attempt++) {
    const x = randRange(-maxEdge, maxEdge);
    const z = randRange(-maxEdge, maxEdge);
    const edge = Math.max(Math.abs(x), Math.abs(z));
    if (edge > maxEdge) continue;
    if (biome && getBiomeAtFromLayout(layout, x, z) !== biome) continue;
    if (layout.oxums && new THREE.Vector2(x - layout.oxums.x, z - layout.oxums.z).length() < minOxumsDist) continue;
    return { x, z };
  }
  return biome === "grass" ? { x:0, z:0 } : { x:randRange(-80, 80), z:randRange(-80, 80) };
}

function createRoadSets(ox, oz) {
  return [
    [
      { x:-148, z:oz - 26 },
      { x:ox - 78, z:oz - 18 },
      { x:ox - 28, z:oz - 6 },
      { x:ox, z:oz }
    ],
    [
      { x:ox, z:oz },
      { x:ox + 28, z:oz - 20 },
      { x:ox + 54, z:oz - 58 },
      { x:Math.min(146, ox + 72), z:oz - 108 }
    ],
    [
      { x:ox - 2, z:oz },
      { x:ox - 26, z:oz + 26 },
      { x:ox - 54, z:oz + 62 },
      { x:ox - 74, z:Math.min(148, oz + 102) }
    ],
    [
      { x:ox + 2, z:oz },
      { x:ox + 32, z:oz + 24 },
      { x:Math.min(138, ox + 62), z:Math.min(126, oz + 68) }
    ]
  ];
}

function createWorldLayout() {
  const layout = {
    noiseX: randRange(-90, 90),
    noiseZ: randRange(-90, 90),
    noiseMix: randRange(-120, 120),
    snowA: { x:randRange(-118, -72), z:randRange(-92, -32), rx:randRange(64, 86), rz:randRange(82, 104) },
    snowB: { x:randRange(-132, -82), z:randRange(-18, 34), rx:randRange(40, 58), rz:randRange(56, 76) },
    desertA: { x:randRange(68, 108), z:randRange(-26, 24), rx:randRange(62, 80), rz:randRange(104, 128) },
    desertB: { x:randRange(102, 132), z:randRange(54, 94), rx:randRange(30, 42), rz:randRange(42, 56) }
  };

  layout.oxums = findRandomWorldSpot(layout, "grass", { maxEdge: 110 });
  layout.spawn = findRandomWorldSpot(layout, null, { minOxumsDist: 34, maxEdge: 118 });
  layout.roads = createRoadSets(layout.oxums.x, layout.oxums.z);
  return layout;
}

const worldLayout = createWorldLayout();
const oxumsPosition = new THREE.Vector3(worldLayout.oxums.x, 0, worldLayout.oxums.z);

/* ---------------------------------------------------------
   LIGHTING
--------------------------------------------------------- */
const hemi = new THREE.HemisphereLight(0xffffff, 0x446655, 0.8);
scene.add(hemi);

const sun = new THREE.DirectionalLight(0xffffff, 1.1);
sun.position.set(80,120,-60);
sun.castShadow = false;
scene.add(sun);
const DAY_NIGHT_SECONDS = 600;

/* ---------------------------------------------------------
   PLAYER
--------------------------------------------------------- */
const player = {
  pos: new THREE.Vector3(worldLayout.spawn.x, 3, worldLayout.spawn.z),
  vel: new THREE.Vector3(0, 0, 0),
  yaw: 0,
  pitch: 0,
  speed: 0.18,
  onGround: false,
  health: 100,
  hunger: 100,
  water: 100,
  radius: 0.7
};

camera.position.copy(player.pos);

/* ---------------------------------------------------------
   INPUT
--------------------------------------------------------- */
const keys = {};
let inventoryOpen = false;
let lootOpen = false;
let inventoryOpenedByLoot = false;
let ignoreMouseLookFrames = 0;
let mapOpen = false;
let activeInventoryTab = "inventory";
let buildMenuOpen = false;
let selectedBuildPiece = null;
let pendingLookX = 0;
let pendingLookY = 0;
let radialMenuOpen = false;
let highlightedBuild = null;

window.addEventListener("keydown", e => {
  const k = e.key.toLowerCase();

  if (k === "m") {
    mapOpen = !mapOpen;
    mapPanel.style.display = mapOpen ? "block" : "none";
    if (mapOpen) {
      drawWorldMap();
      if (document.pointerLockElement === canvas) document.exitPointerLock();
    }
    return;
  }

  if (k === "e") {
    const target = getTargetedBuild();
    if (target && target.userData.isDoor) {
      toggleDoor(target);
      return;
    }
    const lootTarget = getTargetedLootBox();
    if (lootTarget) {
      openLootBox(lootTarget);
      return;
    }
  }

  if (k === "tab") {
    e.preventDefault();
    if (lootOpen) {
      lootOpen = false;
      currentLootBox = null;
      if (inventoryOpenedByLoot) inventoryOpen = false;
      inventoryOpenedByLoot = false;
    } else {
      inventoryOpen = !inventoryOpen;
    }

    updatePanelLayout();

    if (inventoryOpen || lootOpen) {
      if (document.pointerLockElement === canvas) {
        document.exitPointerLock();
      }
    }
    return;
  }

  if (k === "escape") {
    if (radialMenuOpen) {
      closeRadialMenu();
      return;
    }
    if (lootOpen) {
      lootOpen = false;
      currentLootBox = null;
      if (inventoryOpenedByLoot) inventoryOpen = false;
      inventoryOpenedByLoot = false;
      updatePanelLayout();
      return;
    }
    if (inventoryOpen) {
      inventoryOpen = false;
      updatePanelLayout();
      return;
    }
    if (mapOpen) {
      mapOpen = false;
      mapPanel.style.display = "none";
      return;
    }
    if (buildMenuOpen || selectedBuildPiece) {
      buildMenuOpen = false;
      selectedBuildPiece = null;
      updateBuildMenu();
      return;
    }
  }

  if (k === "b") {
    buildMenuOpen = !buildMenuOpen;
    if (!buildMenuOpen) selectedBuildPiece = null;
    if (buildMenuOpen && document.pointerLockElement === canvas) document.exitPointerLock();
    updateBuildMenu();
    return;
  }

  keys[k] = true;

  if (k >= "1" && k <= "6") {
    const index = parseInt(k,10) - 1;
    selectHotbar(index);
  }
});

window.addEventListener("keyup", e => {
  keys[e.key.toLowerCase()] = false;
});

/* ---------------------------------------------------------
   POINTER LOCK
--------------------------------------------------------- */
const canvas = renderer.domElement;

canvas.onclick = () => {
  if (!inventoryOpen && !lootOpen && !buildMenuOpen && !mapOpen && !radialMenuOpen) canvas.requestPointerLock();
};

window.addEventListener("contextmenu", e => {
  e.preventDefault();
});

window.addEventListener("mousedown", e => {
  if (e.button === 0 && radialMenuOpen) {
    closeRadialMenu();
    return;
  }
  if (e.button !== 2) return;
  if (equippedTool === "building_plan") openBuildPieceMenu();
  else if (equippedTool === "hammer") openHammerMenu();
});

document.addEventListener("pointerlockchange", () => {
  if (document.pointerLockElement === canvas) {
    ignoreMouseLookFrames = 2;
    document.addEventListener("mousemove", mouseLook);
  } else {
    ignoreMouseLookFrames = 0;
    document.removeEventListener("mousemove", mouseLook);
  }
});

function mouseLook(e) {
  if (inventoryOpen || lootOpen || mapOpen) return;
  if (ignoreMouseLookFrames > 0) {
    ignoreMouseLookFrames--;
    return;
  }
  pendingLookX += THREE.MathUtils.clamp(e.movementX, -120, 120);
  pendingLookY += THREE.MathUtils.clamp(e.movementY, -90, 90);
}

/* ---------------------------------------------------------
   WORLD OBJECTS
--------------------------------------------------------- */
const interactables = [];
const trees = [];
const rocks = [];
const animals = [];
const lootBoxes = [];
const colliders = [];
const boxColliders = [];
const grassPatches = [];
const fallingTrees = [];
const breakingNodes = [];

const matTrunk   = new THREE.MeshStandardMaterial({ color:0x8b5a2b, roughness:0.9, metalness:0.0 });
const matLeaf    = new THREE.MeshStandardMaterial({ color:0x2e8b57, roughness:0.8, metalness:0.0 });
const matRock    = new THREE.MeshStandardMaterial({ color:0x808080, roughness:0.7, metalness:0.1 });
const matRockDark= new THREE.MeshStandardMaterial({ color:0x555555, roughness:0.8, metalness:0.1 });
const matAnimalBody = new THREE.MeshStandardMaterial({ color:0xc96f53, roughness:0.8, metalness:0.0 });
const matAnimalHead = new THREE.MeshStandardMaterial({ color:0xe0b090, roughness:0.8, metalness:0.0 });
const matBoarBody = new THREE.MeshStandardMaterial({ color:0x8a5d43, roughness:0.9, metalness:0.0 });
const matBoarHead = new THREE.MeshStandardMaterial({ color:0xbc8a68, roughness:0.85, metalness:0.0 });
const matDeerBody = new THREE.MeshStandardMaterial({ color:0x9e6d43, roughness:0.82, metalness:0.0 });
const matDeerHead = new THREE.MeshStandardMaterial({ color:0xd5b08c, roughness:0.8, metalness:0.0 });
const matBearBody = new THREE.MeshStandardMaterial({ color:0x4a3426, roughness:0.96, metalness:0.0 });
const matBearHead = new THREE.MeshStandardMaterial({ color:0x6d5240, roughness:0.92, metalness:0.0 });

/* PARTICLES */
const particles = [];
const particleGeo = new THREE.SphereGeometry(0.08, 6, 6);
const particleMats = {
  wood:  new THREE.MeshStandardMaterial({ color:0x8b5a2b, roughness:1, transparent:true }),
  stone: new THREE.MeshStandardMaterial({ color:0xcccccc, roughness:1, transparent:true }),
  meat:  new THREE.MeshStandardMaterial({ color:0xaa3333, roughness:1, transparent:true })
};
const weatherParticles = [];
const weatherRainMat = new THREE.MeshStandardMaterial({ color:0x8fcaff, transparent:true, opacity:0.65 });
const weatherSnowMat = new THREE.MeshStandardMaterial({ color:0xf4f8ff, transparent:true, opacity:0.9 });

function spawnParticles(pos, type, count=8) {
  const mat = particleMats[type] || particleMats.stone;
  for (let i=0;i<count;i++) {
    const m = new THREE.Mesh(particleGeo, mat.clone());
    m.position.copy(pos);
    scene.add(m);
    const dir = new THREE.Vector3(
      (Math.random()-0.5)*2,
      Math.random()*2,
      (Math.random()-0.5)*2
    ).normalize().multiplyScalar(2);
    particles.push({
      mesh:m,
      vel:dir,
      life:0.5
    });
  }
}

function updateParticles(delta) {
  for (let i=particles.length-1;i>=0;i--) {
    const p = particles[i];
    p.life -= delta;
    p.vel.y -= 4*delta;
    p.mesh.position.addScaledVector(p.vel, delta);
    p.mesh.material.opacity = Math.max(0, p.life*2);
    if (p.life <= 0) {
      scene.remove(p.mesh);
      particles.splice(i,1);
    }
  }
}

