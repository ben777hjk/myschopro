/* ---------------------------------------------------------
   ANIMAL MOVEMENT
--------------------------------------------------------- */
function updateAnimals(delta){
  for(const a of animals){
    const d = a.userData;
    const toPlayer = new THREE.Vector3().subVectors(player.pos, a.position);
    const playerDist = toPlayer.length();
    d.attackCooldown = Math.max(0, d.attackCooldown - delta);

    if ((d.species === "boar" || d.species === "bear") && playerDist < d.aggroRange) {
      d.aggro = true;
    }

    if (d.passiveFlee && playerDist < 7) {
      d.state = "flee";
      d.target.set(
        a.position.x - toPlayer.x * 1.8,
        0,
        a.position.z - toPlayer.z * 1.8
      );
    }

    if (d.aggro) {
      d.state = "chase";
      d.target.copy(player.pos);
    }

    if (d.state === "idle") {
      d.wait -= delta;
      if (d.wait <= 0) {
        const range = 20 + Math.random()*20;
        const angle = Math.random()*Math.PI*2;
        d.target.set(
          a.position.x + Math.cos(angle)*range,
          0,
          a.position.z + Math.sin(angle)*range
        );
        d.state = "walk";
      }
    } else if (d.state === "walk" || d.state === "flee" || d.state === "chase") {
      const dir = new THREE.Vector3().subVectors(d.target, a.position);
      const dist = dir.length();
      if (dist < 1) {
        if (d.state === "chase") {
          d.target.copy(player.pos);
        } else {
          d.state = "idle";
          d.wait = 1 + Math.random()*3;
        }
      } else {
        dir.normalize();
        const speed = d.state === "flee" ? d.speed * 1.1 : d.speed;
        a.position.x += dir.x * speed * delta;
        a.position.z += dir.z * speed * delta;

        const desiredYaw = Math.atan2(dir.x, dir.z);
        d.yaw = THREE.MathUtils.lerp(d.yaw, desiredYaw, 5*delta);
        a.rotation.y = d.yaw;
      }

      if (d.state === "chase" && playerDist < d.attackRange + 0.75 && d.attackCooldown <= 0) {
        player.health = Math.max(0, player.health - d.damage);
        spawnParticles(player.pos.clone().add(new THREE.Vector3(0, 0.8, 0)), "meat", 8);
        d.attackCooldown = d.species === "bear" ? 1.0 : 0.85;
      }
    }
  }
}

/* ---------------------------------------------------------
   PLAYER MOVEMENT + COLLIDERS
--------------------------------------------------------- */
const GRAVITY = -0.012;
const JUMP = 0.27;

function resolveCircleColliders(pos) {
  for (const c of colliders) {
    const dx = pos.x - c.pos.x;
    const dz = pos.z - c.pos.z;
    const dist = Math.sqrt(dx*dx + dz*dz);
    const targetDist = c.radius + player.radius;
    if (dist < targetDist) {
      const overlap = targetDist - dist;
      if (dist > 0.0001) {
        pos.x += (dx/dist)*overlap;
        pos.z += (dz/dist)*overlap;
      } else {
        pos.x += overlap;
      }
    }
  }
}

function resolveBoxColliders(pos) {
  for (let pass = 0; pass < 3; pass++) {
    let changed = false;

    for (const c of boxColliders) {
      const minX = c.minX - player.radius;
      const maxX = c.maxX + player.radius;
      const minZ = c.minZ - player.radius;
      const maxZ = c.maxZ + player.radius;

      if (pos.x > minX && pos.x < maxX && pos.z > minZ && pos.z < maxZ) {
        const pushLeft = Math.abs(pos.x - minX);
        const pushRight = Math.abs(maxX - pos.x);
        const pushTop = Math.abs(pos.z - minZ);
        const pushBottom = Math.abs(maxZ - pos.z);

        const smallest = Math.min(pushLeft, pushRight, pushTop, pushBottom);

        if (smallest === pushLeft) pos.x = minX;
        else if (smallest === pushRight) pos.x = maxX;
        else if (smallest === pushTop) pos.z = minZ;
        else pos.z = maxZ;

        changed = true;
      }
    }

    if (!changed) break;
  }
}

function resolvePlayerCollisions(pos) {
  for (let pass = 0; pass < 3; pass++) {
    const beforeX = pos.x;
    const beforeZ = pos.z;
    resolveCircleColliders(pos);
    resolveBoxColliders(pos);
    if (Math.abs(pos.x - beforeX) < 0.0001 && Math.abs(pos.z - beforeZ) < 0.0001) {
      break;
    }
  }
}

function updatePlayer(delta){
  const sens = 0.0022;
  const appliedLookX = THREE.MathUtils.clamp(pendingLookX, -36, 36);
  const appliedLookY = THREE.MathUtils.clamp(pendingLookY, -28, 28);
  player.yaw -= appliedLookX * sens;
  player.pitch -= appliedLookY * sens;
  pendingLookX -= appliedLookX;
  pendingLookY -= appliedLookY;
  pendingLookX *= 0.15;
  pendingLookY *= 0.15;

  const maxPitch = Math.PI/2 - 0.1;
  player.pitch = Math.max(-maxPitch, Math.min(maxPitch, player.pitch));

  const forward = new THREE.Vector3(Math.sin(player.yaw),0,Math.cos(player.yaw));
  const right   = new THREE.Vector3().crossVectors(forward,new THREE.Vector3(0,1,0));

  let move = new THREE.Vector3();
  if (keys["w"]) move.add(forward);
  if (keys["s"]) move.sub(forward);
  if (keys["a"]) move.sub(right);
  if (keys["d"]) move.add(right);

  let moveAmount = 0;
  if (move.lengthSq()>0){
    move.normalize().multiplyScalar(player.speed);
    player.pos.x += move.x;
    resolvePlayerCollisions(player.pos);
    player.pos.z += move.z;
    resolvePlayerCollisions(player.pos);
    moveAmount = move.length();
  }
  resolvePlayerCollisions(player.pos);

  player.vel.y += GRAVITY;
  player.pos.y += player.vel.y;

  if (player.pos.y < 2){
    player.pos.y = 2;
    player.vel.y = 0;
    player.onGround = true;
  } else {
    player.onGround = false;
  }

  if (keys[" "] && player.onGround){
    player.vel.y = JUMP;
    player.onGround = false;
  }

  const dir = new THREE.Vector3(
    Math.cos(player.pitch)*Math.sin(player.yaw),
    Math.sin(player.pitch),
    Math.cos(player.pitch)*Math.cos(player.yaw)
  );

  camera.position.copy(player.pos);
  camera.lookAt(player.pos.clone().add(dir));

  return moveAmount;
}

/* ---------------------------------------------------------
   GAME LOOP
--------------------------------------------------------- */
let lastTime = performance.now();
setInventoryTab("inventory");
renderCraftingRecipes();
updateCraftQueueUI();
updateBuildMenu();
refreshInventoryUI();
refreshLootUI();
updatePanelLayout();
selectHotbar(0);
updateHud();
startWorldGeneration();

function loop(){
  requestAnimationFrame(loop);
  try {
    const now = performance.now();
    const delta = (now - lastTime) / 1000;
    lastTime = now;

    updateDayNightCycle(now);
    updateBiomeAtmosphere(now, delta);
    const moveAmount = updatePlayer(delta);
    updateAnimals(delta);
    updateVitals(delta);
    updateToolAnimation(delta, moveAmount);
    updateEquippedTool();
    updateParticles(delta);
    updateFallingTrees(delta);
    updateBreakingNodes(delta);
    updatePlacedBuilds(delta);
    finishCraftingIfReady();
    updateCraftQueueUI();
    updateBuildPreview();
    updateHud();
    if (mapOpen) drawWorldMap();
    renderer.render(scene,camera);
  } catch (err) {
    showErrorOverlay(err);
  }
}
loop();

/* ---------------------------------------------------------
   RESIZE
--------------------------------------------------------- */
onresize = () => {
  camera.aspect = innerWidth/innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(innerWidth, innerHeight);
  if (mapOpen) drawWorldMap();
};
