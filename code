function spawnWeatherParticle(type) {
  const isRain = type === "rain";
  const startY = type === "snow" ? Math.max(22, player.pos.y + 22 + Math.random() * 10) : player.pos.y + 10 + Math.random() * 8;
  const mesh = new THREE.Mesh(
    isRain ? new THREE.BoxGeometry(0.035, 0.5, 0.035) : new THREE.SphereGeometry(0.05, 5, 5),
    isRain ? weatherRainMat : weatherSnowMat
  );
  mesh.position.set(
    player.pos.x + (Math.random()-0.5) * 26,
    startY,
    player.pos.z + (Math.random()-0.5) * 26
  );
  scene.add(mesh);
  weatherParticles.push({
    mesh,
    type,
    vel: new THREE.Vector3(
      isRain ? -0.7 : (Math.random()-0.5) * 0.35,
      isRain ? -11 : -(3.6 + Math.random()*2.0),
      isRain ? 0.4 : (Math.random()-0.5) * 0.35
    ),
    life: isRain ? 1.4 : 9
  });
}

function updateWeatherParticles(delta, biome, isRaining) {
  const targetType = biome === "snow" ? "snow" : (isRaining ? "rain" : null);
  const spawnCount = targetType === "snow" ? 5 : targetType === "rain" ? 10 : 0;
  for (let i=0; i<spawnCount; i++) spawnWeatherParticle(targetType);

  for (let i=weatherParticles.length-1; i>=0; i--) {
    const p = weatherParticles[i];
    p.life -= delta;
    p.mesh.position.addScaledVector(p.vel, delta);
    if (p.type === "snow") p.mesh.position.x += Math.sin((performance.now()*0.001) + i) * delta * 0.25;
    if (p.mesh.position.y <= 0 || p.life <= 0) {
      scene.remove(p.mesh);
      weatherParticles.splice(i, 1);
    }
  }
}

function startTreeFall(tree) {
  removeFromArray(interactables, tree);
  removeFromArray(trees, tree);
  removeCircleColliderNear(tree.position, 0.1);
  tree.userData.falling = true;
  tree.userData.fallDir = new THREE.Vector3(Math.sin(player.yaw), 0, Math.cos(player.yaw)).normalize();
  if (tree.userData.fallDir.lengthSq() < 0.01) tree.userData.fallDir.set(1,0,0);
  tree.userData.fallProgress = 0;
  fallingTrees.push(tree);
  spawnParticles(tree.position.clone().add(new THREE.Vector3(0, 2, 0)), "wood", 24);
}

function startNodeBreak(node) {
  removeFromArray(interactables, node);
  removeFromArray(rocks, node);
  removeCircleColliderNear(new THREE.Vector3(node.position.x, 0, node.position.z), 0.1);
  node.userData.breaking = true;
  node.userData.breakProgress = 0;
  breakingNodes.push(node);
  spawnParticles(node.position.clone().add(new THREE.Vector3(0, 1.2, 0)), "stone", 22);
}

function updateFallingTrees(delta) {
  for (let i=fallingTrees.length-1; i>=0; i--) {
    const tree = fallingTrees[i];
    tree.userData.fallProgress += delta * 0.9;
    const p = Math.min(tree.userData.fallProgress, 1);
    const dir = tree.userData.fallDir;
    tree.rotation.z = dir.x * (-Math.PI * 0.48 * p);
    tree.rotation.x = dir.z * (Math.PI * 0.48 * p);
    if (p >= 1) {
      scene.remove(tree);
      fallingTrees.splice(i, 1);
    }
  }
}

function updateBreakingNodes(delta) {
  for (let i=breakingNodes.length-1; i>=0; i--) {
    const node = breakingNodes[i];
    node.userData.breakProgress += delta * 1.8;
    const p = Math.min(node.userData.breakProgress, 1);
    const scale = Math.max(0.01, 1 - p);
    node.scale.setScalar(scale);
    node.position.y = 1 - p * 1.2;
    node.rotation.y += delta * 5;
    if (p >= 1) {
      scene.remove(node);
      breakingNodes.splice(i, 1);
    }
  }
}

