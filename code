    } else {
      addMesh(new THREE.BoxGeometry(5.1, 0.16, 0.18), mats.detail, 0, 1.5, 0, 0, 0, 0.66);
      addMesh(new THREE.BoxGeometry(5.1, 0.16, 0.18), mats.detail, 0, 1.5, 0, 0, 0, -0.66);
    }
    return { group, highlightMeshes };
  }

  if (isWallLike && tier === "wood") {
    if (!isFrame) addMesh(new THREE.BoxGeometry(3.72, 2.74, 0.12), mats.panel, 0, 1.5, -0.02);
    for (let x=-1.56; x<=1.56; x+=0.42) {
      if (isFrame && Math.abs(x) < openingWidth * 0.5) continue;
      addMesh(new THREE.BoxGeometry(0.24, 2.86, 0.16), mats.detail, x, 1.5, 0.02);
    }
    addMesh(new THREE.BoxGeometry(3.92, 0.18, 0.2), mats.beam, 0, 0.34, 0.04);
    addMesh(new THREE.BoxGeometry(3.92, 0.18, 0.2), mats.beam, 0, 1.5, 0.04);
    addMesh(new THREE.BoxGeometry(3.92, 0.18, 0.2), mats.beam, 0, 2.66, 0.04);
    if (isFrame) {
      addMesh(new THREE.BoxGeometry(0.26, 3.0, 0.2), mats.beam, -1.78, 1.5, 0.04);
      addMesh(new THREE.BoxGeometry(0.26, 3.0, 0.2), mats.beam, 1.78, 1.5, 0.04);
      addMesh(new THREE.BoxGeometry(4.0, 0.22, 0.22), mats.beam, 0, 2.82, 0.04);
    } else {
      addMesh(new THREE.BoxGeometry(5.05, 0.16, 0.16), mats.beam, 0, 1.5, 0.08, 0, 0, 0.66);
      addMesh(new THREE.BoxGeometry(5.05, 0.16, 0.16), mats.beam, 0, 1.5, 0.08, 0, 0, -0.66);
    }
    return { group, highlightMeshes };
  }

  if (isWallLike && tier === "stone") {
    addMesh(new THREE.BoxGeometry(3.94, 2.98, isFrame ? 0.26 : 0.28), mats.panel, 0, 1.5, 0);
    const blocks = [
      [-1.25, 0.48, 0.86, 0.44], [-0.18, 0.46, 0.74, 0.36], [0.96, 0.5, 0.9, 0.42],
      [-1.48, 1.18, 0.72, 0.34], [-0.52, 1.22, 0.88, 0.4], [0.58, 1.14, 0.8, 0.32], [1.46, 1.24, 0.64, 0.32],
      [-1.12, 1.92, 0.92, 0.42], [0.08, 1.88, 1.1, 0.42], [1.34, 1.96, 0.84, 0.38], 
      [-1.46, 2.56, 0.74, 0.28], [-0.28, 2.56, 0.82, 0.3], [0.82, 2.6, 0.9, 0.3], [1.66, 2.58, 0.46, 0.26]
    ];
    for (const [x, y, w, h] of blocks) {
      if (isFrame && Math.abs(x) < openingWidth * 0.5 && y < 2.42) continue;
      addMesh(new THREE.BoxGeometry(w, h, 0.08), mats.detail, x, y, 0.16);
    }
    if (isFrame) {
      addMesh(new THREE.BoxGeometry(0.34, 3.0, 0.34), mats.beam, -1.82, 1.5, 0);
      addMesh(new THREE.BoxGeometry(0.34, 3.0, 0.34), mats.beam, 1.82, 1.5, 0);
      addMesh(new THREE.BoxGeometry(4.0, 0.32, 0.34), mats.beam, 0, 2.84, 0);
    }
    return { group, highlightMeshes };
  }

  addMesh(new THREE.BoxGeometry(piece.size.x, piece.size.y, piece.size.z), mats.panel, 0, piece.category === "wall" ? 1.5 : piece.id === "foundation" ? 0.5 : piece.id === "ceiling" ? 3 : 0.25, 0);
  return { group, highlightMeshes };
}

function getLookTargetFrom(objects, maxDist = 7) {
  ray.setFromCamera({x:0,y:0}, camera);
  const hits = ray.intersectObjects(objects, true);
  if (!hits.length || hits[0].distance > maxDist) return null;
  let obj = hits[0].object;
  while (obj.parent && obj.parent !== scene && !obj.userData.isPlacedBuild) obj = obj.parent;
  return obj.userData.isPlacedBuild ? obj : null;
}

function getTargetedBuild() {
  const roots = placedBuilds.map(b => b.root);
  return getLookTargetFrom(roots, 8);
}

function getTargetedLootBox() {
  ray.setFromCamera({x:0,y:0}, camera);
  const hits = ray.intersectObjects(interactables, true);
  if (!hits.length || hits[0].distance > 6) return null;
  let obj = hits[0].object;
  while (obj.parent && obj.parent !== scene) obj = obj.parent;
  return obj.userData && obj.userData.type === "lootbox" ? obj : null;
}

function getBuildSnapHit(maxDist = 8) {
  const roots = placedBuilds.map(b => b.root);
  ray.setFromCamera({x:0,y:0}, camera);
  const hits = ray.intersectObjects(roots, true);
  if (!hits.length || hits[0].distance > maxDist) return null;
  let obj = hits[0].object;
  while (obj.parent && obj.parent !== scene && !obj.userData.isPlacedBuild) obj = obj.parent;
  if (!obj.userData.isPlacedBuild) return null;
  return { root: obj, point: hits[0].point.clone() };
}

function getBuildLayer(piece) {
  if (!piece) return "wall";
  if (piece.category === "door") return "door";
  if (piece.id === "ceiling") return "ceiling";
  if (piece.id === "floor" || piece.id === "foundation") return "floor";
  return "wall";
}

function clearBuildHighlight() {
  if (!highlightedBuild) return;
  for (const mesh of highlightedBuild.userData.highlightMeshes || []) {
    mesh.material.emissive?.setHex(mesh.userData.baseEmissive || 0x000000);
    mesh.material.emissiveIntensity = mesh.userData.baseEmissiveIntensity ?? 0;
  }
  highlightedBuild = null;
}

function setBuildHighlight(build) {
  if (highlightedBuild === build) return;
  clearBuildHighlight();
  if (!build) return;
  for (const mesh of build.userData.highlightMeshes || []) {
    mesh.userData.baseEmissive = mesh.material.emissive ? mesh.material.emissive.getHex() : 0x000000;
    mesh.userData.baseEmissiveIntensity = mesh.material.emissiveIntensity || 0;
    if (mesh.material.emissive) {
      mesh.material.emissive.setHex(0x3a9bff);
      mesh.material.emissiveIntensity = 0.55;
    }
  }
  highlightedBuild = build;
}

function getBuildPlacement(piece) {
  const yawSnap = Math.round(player.yaw / (Math.PI * 0.5)) * (Math.PI * 0.5);
  const offset = new THREE.Vector3(Math.sin(yawSnap), 0, Math.cos(yawSnap)).multiplyScalar(6);
  const rawX = player.pos.x + offset.x;
  const rawZ = player.pos.z + offset.z;
  return {
    x: Math.round(rawX / 4) * 4,
    z: Math.round(rawZ / 4) * 4,
    yaw: yawSnap
  };
}

function getNearestPlacedBuild(maxDist = 8) {
  let nearest = null;
  let best = maxDist;
  for (const build of placedBuilds) {
    if (build.root.userData.isDoor) continue;
    const dist = new THREE.Vector2(build.root.position.x - player.pos.x, build.root.position.z - player.pos.z).length();
    if (dist < best) {
      best = dist;
      nearest = build;
    }
  }
  return nearest;
}

function getNearestPlacedBuildTo(x, z, maxDist = 8) {
  let nearest = null;
  let best = maxDist;
  for (const build of placedBuilds) {
    if (build.root.userData.isDoor) continue;
    const dx = build.root.position.x - x;
    const dz = build.root.position.z - z;
    const dist = Math.sqrt(dx*dx + dz*dz);
    if (dist < best) {
      best = dist;
      nearest = build;
    }
  }
  return nearest;
}

function isPlacementOccupied(x, z, minDist = 2.4, piece = null) {
  const targetLayer = getBuildLayer(piece);
  return placedBuilds.some(build => {
    const buildLayer = build.layer || getBuildLayer(build.piece);
    const sameLayer = buildLayer === targetLayer;
    const floorConflict = (targetLayer === "floor" && buildLayer === "floor");
    if (!sameLayer && !floorConflict) return false;
    const dx = build.root.position.x - x;
    const dz = build.root.position.z - z;
    return Math.sqrt(dx*dx + dz*dz) < minDist;
  });
}

function findAdjacentBuildPlacement(near, rawX, rawZ, yaw, piece) {
  const options = [
    { x: near.root.position.x + 4, z: near.root.position.z },
    { x: near.root.position.x - 4, z: near.root.position.z },
    { x: near.root.position.x, z: near.root.position.z + 4 },
    { x: near.root.position.x, z: near.root.position.z - 4 }
  ];

  options.sort((a, b) => {
    const da = (a.x - rawX) * (a.x - rawX) + (a.z - rawZ) * (a.z - rawZ);
    const db = (b.x - rawX) * (b.x - rawX) + (b.z - rawZ) * (b.z - rawZ);
    return da - db;
  });

  for (const option of options) {
    if (!isPlacementOccupied(option.x, option.z, piece.category === "wall" ? 2.2 : 2.8, piece)) {
      return { x: option.x, z: option.z, y: 0, yaw };
    }
  }

  return null;
}

function computeBuildPlacement(piece) {
  if (piece.category === "door") {
    const frame = getTargetedBuild();
    if (!frame || !frame.userData.frameType || frame.userData.frameType !== piece.doorType || frame.userData.hasDoor) {
      return { valid:false, visible:false };
    }
    return {
      valid:true,
      visible:true,
      x: frame.position.x,
      z: frame.position.z,
      y: 0,
      yaw: frame.rotation.y,
      snapTarget: frame
    };
  }

  let placement = getBuildPlacement(piece);
  const rawX = placement.x;
  const rawZ = placement.z;
  const snapHit = getBuildSnapHit();
  if (snapHit) {
    const root = snapHit.root;
    if (piece.id === "floor" || piece.id === "ceiling" || piece.id === "foundation") {
      placement = {
        x: root.position.x,
        z: root.position.z,
        y: 0,
        yaw: root.rotation.y
      };
    } else {
      const dx = snapHit.point.x - root.position.x;
      const dz = snapHit.point.z - root.position.z;
      if (Math.abs(dx) > Math.abs(dz)) {
        placement = {
          x: root.position.x + (dx >= 0 ? 4 : -4),
          z: root.position.z,
          y: 0,
          yaw: Math.PI * 0.5
        };
      } else {
        placement = {
          x: root.position.x,
          z: root.position.z + (dz >= 0 ? 4 : -4),
          y: 0,
          yaw: 0
        };
      }
    }
  } else {
    const near = getNearestPlacedBuildTo(rawX, rawZ);
    if (near) {
      const snapped = findAdjacentBuildPlacement(near, rawX, rawZ, placement.yaw, piece);
      if (snapped) placement = snapped;
      else return { ...placement, valid:false, visible:false };
    } else {
      placement.y = 0;
    }
  }

  const occupied = isPlacementOccupied(placement.x, placement.z, piece.category === "wall" ? 2.2 : 2.8, piece);
  return { ...placement, valid: !occupied, visible: !occupied };
}

function rebuildPreviewMesh(piece) {
  buildPreview.clear();
  if (!piece) {
    buildPreview.visible = false;
    return;
  }
  const visual = createBuildVisual(piece, "twig", true);
  buildPreview.add(visual.group);
  buildPreview.visible = true;
}

function updateBuildMenu() {
  buildMenu.style.display = buildMenuOpen ? "flex" : "none";
  buildMenu.innerHTML = "";

  for (const piece of buildPieces) {
    const card = document.createElement("button");
    card.className = "buildCard";
    if (selectedBuildPiece === piece.id) card.classList.add("active");
    card.innerHTML = `
      <div class="recipeTitle">${piece.name}</div>
      <div class="recipeMeta">${costsText(piece.costs)}</div>
    `;
    card.addEventListener("click", () => {
      selectedBuildPiece = selectedBuildPiece === piece.id ? null : piece.id;
      buildMenuOpen = false;
      rebuildPreviewMesh(getBuildPiece(selectedBuildPiece));
      updateBuildMenu();
    });
    buildMenu.appendChild(card);
  }
}

function addPlacedBuildColliders(piece, placement) {
  if (piece.id === "foundation" || piece.id === "floor") {
    addBoxCollider(placement.x, placement.z, 2, 2);
  } else if (piece.id === "ceiling") {
    addBoxCollider(placement.x, placement.z, 2, 2);
  } else if (piece.id === "wall") {
    if (Math.abs(Math.sin(placement.yaw)) > 0.5) addBoxCollider(placement.x, placement.z, 0.2, 2);
    else addBoxCollider(placement.x, placement.z, 2, 0.2);
  } else if (piece.id === "single_door_frame" || piece.id === "double_door_frame") {
    if (Math.abs(Math.sin(placement.yaw)) > 0.5) {
      addBoxCollider(placement.x, placement.z - 1.75, 0.2, 0.25);
      addBoxCollider(placement.x, placement.z + 1.75, 0.2, 0.25);
    } else {
      addBoxCollider(placement.x - 1.75, placement.z, 0.25, 0.2);
      addBoxCollider(placement.x + 1.75, placement.z, 0.25, 0.2);
    }
  }
}

function placeBuildPiece() {
  const piece = getBuildPiece(selectedBuildPiece);
  if (!piece || !hasRecipeCosts(piece)) return false;

  const placement = computeBuildPlacement(piece);
  if (!placement.valid) return false;

  if (piece.category === "door") {
    const frame = placement.snapTarget;
    const doorRoot = new THREE.Group();
    doorRoot.userData.isPlacedBuild = true;
    doorRoot.userData.buildType = piece.id;
    doorRoot.userData.tier = "twig";
    doorRoot.userData.isDoor = true;
    doorRoot.userData.open = false;
    doorRoot.userData.targetAngle = 0;
    doorRoot.userData.frameType = piece.doorType;
    const doorMat = new THREE.MeshStandardMaterial({ color:0x8f673b, roughness:0.9 });
    const doorMesh = new THREE.Mesh(new THREE.BoxGeometry(piece.size.x, piece.size.y, piece.size.z), doorMat);
    doorMesh.position.set(piece.id === "single_wood_door" ? -0.8 : 0, piece.size.y*0.5, 0);
    doorMesh.castShadow = true;
    doorMesh.receiveShadow = true;
    doorRoot.add(doorMesh);
    doorRoot.position.copy(frame.position);
    doorRoot.rotation.y = frame.rotation.y;
    doorRoot.userData.highlightMeshes = [doorMesh];
    frame.add(doorRoot);
    frame.userData.hasDoor = true;
    frame.userData.doorRef = doorRoot;
    placedBuilds.push({ root:doorRoot, piece, tier:"twig", type:piece.id, layer:getBuildLayer(piece) });
    for (const cost of piece.costs) removeItem(cost.item, cost.count);
    return true;
  }

  const build = new THREE.Group();
  build.userData.isPlacedBuild = true;
  build.userData.buildType = piece.id;
  build.userData.pieceId = piece.id;
  build.userData.tier = "twig";
  const visual = createBuildVisual(piece, "twig", false);
  build.add(visual.group);
  let highlightMeshes = visual.highlightMeshes;
  build.userData.visualGroup = visual.group;

  build.position.set(placement.x, 0, placement.z);
  build.rotation.y = placement.yaw;
  build.userData.highlightMeshes = highlightMeshes;
  build.userData.stability = 52;
  build.userData.maxHealth = 200;
  if (piece.id === "single_door_frame" || piece.id === "double_door_frame") {
    build.userData.frameType = piece.doorType;
    build.userData.hasDoor = false;
  }
  scene.add(build);
  placedBuilds.push({ root:build, piece, tier:"twig", type:piece.id, layer:getBuildLayer(piece) });

  for (const cost of piece.costs) removeItem(cost.item, cost.count);
  addPlacedBuildColliders(piece, placement);
  renderCraftingRecipes();
  return true;
}

function updateBuildPreview() {
  if (equippedTool !== "building_plan" || !selectedBuildPiece) {
    buildPreview.visible = false;
    return;
  }
  const piece = getBuildPiece(selectedBuildPiece);
  if (!piece) {
    buildPreview.visible = false;
    return;
  }
  const placement = computeBuildPlacement(piece);
  if (!placement.visible) {
    buildPreview.visible = false;
    return;
  }
  rebuildPreviewMesh(piece);
  buildPreview.position.set(placement.x, placement.y || 0, placement.z);
  buildPreview.rotation.y = placement.yaw;
}

function applyTierToBuild(buildRoot, tier) {
  const piece = getBuildPiece(buildRoot.userData.pieceId || buildRoot.userData.buildType);
  if (!piece) return;
  if (buildRoot.userData.visualGroup) buildRoot.remove(buildRoot.userData.visualGroup);
  const visual = createBuildVisual(piece, tier, false);
  buildRoot.add(visual.group);
  buildRoot.userData.visualGroup = visual.group;
  buildRoot.userData.highlightMeshes = visual.highlightMeshes;
  buildRoot.userData.tier = tier;
  buildRoot.userData.maxHealth = tier === "stone" ? 500 : tier === "wood" ? 250 : 120;
}

