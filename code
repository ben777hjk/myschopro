function createBuildVisual(piece, tier = "twig", preview = false) {
  const group = new THREE.Group();
  const highlightMeshes = [];
  const addMesh = (geo, mat, x=0, y=0, z=0, rx=0, ry=0, rz=0) => {
    const mesh = new THREE.Mesh(geo, mat);
    mesh.position.set(x, y, z);
    mesh.rotation.set(rx, ry, rz);
    mesh.castShadow = !preview;
    mesh.receiveShadow = !preview;
    group.add(mesh);
    highlightMeshes.push(mesh);
    return mesh;
  };

  const mats = preview ? {
    panel: createBuildMaterial(0x76c6ff, true),
    beam: createBuildMaterial(0x76c6ff, true),
    detail: createBuildMaterial(0x9de0ff, true)
  } : tier === "stone" ? {
    panel: createBuildMaterial(0x62574d, false, { roughness:1.0 }),
    beam: createBuildMaterial(0x4e4741, false, { roughness:1.0 }),
    detail: createBuildMaterial(0x7a6f62, false, { roughness:0.98 })
  } : tier === "wood" ? {
    panel: createBuildMaterial(0x4f3325, false, { roughness:0.92 }),
    beam: createBuildMaterial(0x6b4b35, false, { roughness:0.88 }),
    detail: createBuildMaterial(0x866148, false, { roughness:0.84 })
  } : {
    panel: createBuildMaterial(0x6a5137, false, { roughness:0.96 }),
    beam: createBuildMaterial(0x7d6144, false, { roughness:0.95 }),
    detail: createBuildMaterial(0x9b7b59, false, { roughness:0.92 })
  };

  const isFrame = piece.id === "single_door_frame" || piece.id === "double_door_frame";
  const isWallLike = piece.id === "wall" || isFrame;
  const openingWidth = piece.id === "double_door_frame" ? 3.0 : 1.65;

  if (piece.id === "foundation") {
    addMesh(new THREE.BoxGeometry(4, 0.9, 4), mats.panel, 0, 0.45, 0);
