function createDetailedLootCrate(colorA, colorB) {
  const g = new THREE.Group();

  const woodMat = new THREE.MeshStandardMaterial({ color:colorA, roughness:0.95 });
  const trimMat = new THREE.MeshStandardMaterial({ color:colorB, roughness:0.55, metalness:0.2 });
