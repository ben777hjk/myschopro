function addRoad(points, width = 8) {
  for (let i=0; i<points.length-1; i++) {
    const a = points[i];
    const b = points[i+1];
    const dx = b.x - a.x;
    const dz = b.z - a.z;
    const len = Math.sqrt(dx*dx + dz*dz);
    const road = new THREE.Mesh(new THREE.PlaneGeometry(width, len), roadMat);
    road.rotation.x = -Math.PI/2;
    road.rotation.z = Math.atan2(dx, dz);
    road.position.set((a.x + b.x) * 0.5, 0.025, (a.z + b.z) * 0.5);
    road.receiveShadow = true;
    scene.add(road);
  }
}

