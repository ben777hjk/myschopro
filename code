          const z = centerZ + (Math.random()-0.5)*cellSize*0.95;
          spawnGrassPatch(x,z, 3 + Math.floor(Math.random()*3));
        }

      } else {
        const treeCount = 4 + Math.floor(Math.random()*3);
        const rockCount = Math.floor(Math.random()*2);
        const boarCount = Math.floor(Math.random()*2);
        const deerCount = Math.floor(Math.random()*2);
        const bearCount = Math.random() < 0.2 ? 1 : 0;
        const grassCount = 1 + Math.floor(Math.random()*2);

        for (let i=0;i<treeCount;i++) {
          const x = centerX + (Math.random()-0.5)*cellSize*0.8;
          const z = centerZ + (Math.random()-0.5)*cellSize*0.8;
          spawnTree(x,z);
        }
        for (let i=0;i<rockCount;i++) {
          const x = centerX + (Math.random()-0.5)*cellSize*0.9;
          const z = centerZ + (Math.random()-0.5)*cellSize*0.9;
          spawnRock(x,z);
        }
        for (let i=0;i<boarCount;i++) {
          const x = centerX + (Math.random()-0.5)*cellSize*0.9;
          const z = centerZ + (Math.random()-0.5)*cellSize*0.9;
