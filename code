function generateWorldBiomes() {
  const radius = 160;
  const cellSize = 70;
  const half = radius;

  for (let gx = -half; gx < half; gx += cellSize) {
    for (let gz = -half; gz < half; gz += cellSize) {

      const centerX = gx + (Math.random()-0.5)*cellSize*0.4;
      const centerZ = gz + (Math.random()-0.5)*cellSize*0.4;
      const zone = getBiomeAt(centerX, centerZ);

      if (zone === "water" || zone === "beach") continue;

      let biomeType = zone === "snow" ? "forest" : zone === "desert" ? "plains" : (Math.random() < 0.62 ? "forest" : "plains");

      if (Math.abs(centerX - worldLayout.oxums.x) < 38 && Math.abs(centerZ - worldLayout.oxums.z) < 32) continue;

      if (biomeType === "forest") {
        const treeCount = 12 + Math.floor(Math.random()*6);
        const rockCount = Math.floor(Math.random()*2);
        const boarCount = Math.floor(Math.random()*2);
        const deerCount = 1 + Math.floor(Math.random()*2);
        const grassCount = 3 + Math.floor(Math.random()*3);

        for (let i=0;i<treeCount;i++) {
          const x = centerX + (Math.random()-0.5)*cellSize*0.7;
          const z = centerZ + (Math.random()-0.5)*cellSize*0.7;
          spawnTree(x,z);
        }
        for (let i=0;i<rockCount;i++) {
          const x = centerX + (Math.random()-0.5)*cellSize*0.6;
          const z = centerZ + (Math.random()-0.5)*cellSize*0.6;
          spawnRock(x,z);
        }
        for (let i=0;i<boarCount;i++) {
