  craftQueueText.textContent = "Crafting " + activeCraft.name + "... " + Math.ceil(Math.max(0, activeCraft.time - elapsed / 1000)) + "s";
  craftProgressFill.style.width = (progress * 100).toFixed(0) + "%";
}

function renderCraftingRecipes() {
  craftingGrid.innerHTML = "";
  for (const recipe of recipes) {
    const card = document.createElement("button");
    card.className = "recipeCard";
    const canCraft = hasRecipeCosts(recipe) && !activeCraft;
    if (!canCraft) card.classList.add("disabled");

    const costs = recipe.costs.map(cost => itemName(cost.item) + " x" + cost.count).join(", ");
    card.innerHTML = `
      <div class="recipeTitle">${recipe.name}</div>
      <div class="recipeMeta">Craft time: ${recipe.time}s</div>
      <div class="recipeMeta">Cost: ${costs}</div>
    `;
    card.addEventListener("click", () => {
      if (!hasRecipeCosts(recipe) || activeCraft) return;
      for (const cost of recipe.costs) removeItem(cost.item, cost.count);
      activeCraft = {
        id: recipe.id,
        name: recipe.name,
        time: recipe.time,
        startedAt: performance.now(),
        produces: recipe.produces
      };
      updateCraftQueueUI();
      renderCraftingRecipes();
    });
    craftingGrid.appendChild(card);
  }
}

function finishCraftingIfReady() {
