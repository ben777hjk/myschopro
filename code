function makeTerrainMaterial(colorA, colorB, size = 96) {
  const canvas = document.createElement("canvas");
  canvas.width = size;
  canvas.height = size;
  const ctx = canvas.getContext("2d");
  ctx.fillStyle = "#" + colorA.toString(16).padStart(6, "0");
  ctx.fillRect(0, 0, size, size);
  ctx.fillStyle = "#" + colorB.toString(16).padStart(6, "0");
  for (let i=0; i<220; i++) {
    ctx.globalAlpha = 0.08 + Math.random()*0.08;
    ctx.beginPath();
    ctx.arc(Math.random()*size, Math.random()*size, 1 + Math.random()*3, 0, Math.PI*2);
    ctx.fill();
  }
  ctx.globalAlpha = 1;
  const tex = new THREE.CanvasTexture(canvas);
  tex.wrapS = THREE.RepeatWrapping;
  tex.wrapT = THREE.RepeatWrapping;
  tex.repeat.set(14, 14);
  return new THREE.MeshStandardMaterial({ map:tex, roughness:1.0, metalness:0.0 });
}

