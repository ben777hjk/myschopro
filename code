/* swing + sway */
let swingTime = 0;
let swingActive = false;

function startSwing() {
  if (equippedTool === "none") return;
  if (swingActive) return;
  swingActive = true;
  swingTime = 0;
}

function updateToolAnimation(delta, moveAmount) {
  const swayStrength = 0.08;
  const swaySpeed = 6;
  const t = performance.now() * 0.001;
  const sway = Math.sin(t * swaySpeed) * swayStrength * Math.min(moveAmount*5,1);

  toolGroup.rotation.z = sway;
  toolGroup.rotation.x = -0.4;

  if (swingActive) {
    swingTime += delta * 5;
    const p = Math.min(swingTime, 1);
    const angle = Math.sin(p * Math.PI) * 0.8;
    toolGroup.rotation.x = -0.4 + angle;
    if (p >= 1) {
      swingActive = false;
      toolGroup.rotation.x = -0.4;
    }
  }
}

/* ---------------------------------------------------------
   RAYCAST HIT + LOOT OPEN
--------------------------------------------------------- */
const ray = new THREE.Raycaster();
let currentLootBox = null;

window.addEventListener("click", () => {
  if (inventoryOpen || lootOpen) return;

  if (equippedTool === "building_plan" && selectedBuildPiece) {
    placeBuildPiece();
    return;
  }

  if (document.pointerLockElement !== canvas) return;

  startSwing();

  ray.setFromCamera({x:0,y:0}, camera);
  const hits = ray.intersectObjects(interactables, true);
  if (!hits.length) return;

  const hit = hits[0];
  if (hit.distance > 6) return;

  let obj = hit.object;
  while (obj.parent && obj.parent !== scene) obj = obj.parent;

  const data = obj.userData;

  if (data.type === "lootbox") return;

  let damage = 1;

  if (data.type === "tree") {
    const redX = data.redX;
    if (redX && redX.mesh) {
      const xWorld = new THREE.Vector3();
      redX.mesh.getWorldPosition(xWorld);
      if (xWorld.distanceTo(hit.point) < 1.0) {
        damage = 3;
        spawnParticles(hit.point, "wood", 14);
        moveTreeRedXSlightly(obj);
      } else {
        spawnParticles(hit.point, "wood", 8);
      }
    } else {
      spawnParticles(hit.point, "wood", 8);
    }
  } else if (data.type === "rock") {
    const shineData = data.shine;
    if (shineData && shineData.mesh) {
      const shineWorld = new THREE.Vector3();
      shineData.mesh.getWorldPosition(shineWorld);
      if (shineWorld.distanceTo(hit.point) < 1.0) {
        damage = 3;
        spawnParticles(hit.point, "stone", 14);
        moveRockShineSlightly(obj);
      } else {
        spawnParticles(hit.point, "stone", 8);
      }
    } else {
      spawnParticles(hit.point, "stone", 8);
    }
  } else if (data.type === "animal") {
    spawnParticles(hit.point, "meat", 10);
    if (data.species === "boar" || data.species === "bear") {
      data.aggro = true;
      data.state = "chase";
      data.target.copy(player.pos);
    } else if (data.species === "deer") {
      data.state = "flee";
      data.target.set(
        obj.position.x - Math.sin(player.yaw) * 12,
        0,
        obj.position.z - Math.cos(player.yaw) * 12
      );
    }
  }

  data.hp -= damage;

  if (data.hp <= 0){
    if (data.type==="tree") {
      if (equippedTool === "axe") addItem("wood",4);
      else addItem("wood",2);
      startTreeFall(obj);
    }
    if (data.type==="rock") {
      if (equippedTool === "pickaxe") addItem("stone",4);
      else addItem("stone",2);
      startNodeBreak(obj);
    }
    if (data.type==="animal") {
      addItem("meat", data.species === "bear" ? 3 : 1);
      scene.remove(obj);
      removeFromArray(interactables, obj);
      removeFromArray(animals, obj);
    }
  }
});

