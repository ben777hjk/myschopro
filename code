function addItem(type, amount) {
  while (amount > 0) {
    for (let i=0;i<SLOT_COUNT && amount>0;i++) {
      const s = slots[i];
      if (s.item === type && s.count < MAX_STACK) {
        const space = MAX_STACK - s.count;
        const add = Math.min(space, amount);
        s.count += add;
        amount -= add;
      }
    }
    if (amount <= 0) break;

    let emptyIndex = -1;
    for (let i=0;i<SLOT_COUNT;i++) {
      if (!slots[i].item) { emptyIndex = i; break; }
    }
    if (emptyIndex === -1) break;
    const add = Math.min(MAX_STACK, amount);
    slots[emptyIndex].item = type;
    slots[emptyIndex].count = add;
    amount -= add;
  }
  refreshInventoryUI();
  renderCraftingRecipes();
}

function removeItem(type, amount) {
  for (let i=0;i<SLOT_COUNT;i++) {
    const s = slots[i];
    if (s.item === type) {
      const take = Math.min(s.count, amount);
      s.count -= take;
      amount -= take;
      if (s.count <= 0) {
        s.item = null;
        s.count = 0;
      }
      if (amount <= 0) break;
    }
  }
  refreshInventoryUI();
  renderCraftingRecipes();
}

function totalOf(type) {
  let t = 0;
  for (const s of slots) if (s.item === type) t += s.count;
  return t;
}

function hasRecipeCosts(recipe) {
  return recipe.costs.every(cost => totalOf(cost.item) >= cost.count);
}

