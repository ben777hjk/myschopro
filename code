function openBuildPieceMenu() {
  if (document.pointerLockElement === canvas) document.exitPointerLock();
  if (!selectedBuildPiece) selectedBuildPiece = "wall";
  openRadialMenu(innerWidth * 0.5, innerHeight * 0.5, [
    { label:"Wall", meta:"Twig wall piece", onClick: () => { selectedBuildPiece = "wall"; rebuildPreviewMesh(getBuildPiece(selectedBuildPiece)); } },
    { label:"Floor", meta:"Snap floor tile", onClick: () => { selectedBuildPiece = "floor"; rebuildPreviewMesh(getBuildPiece(selectedBuildPiece)); } },
    { label:"Ceiling", meta:"Upper floor tile", onClick: () => { selectedBuildPiece = "ceiling"; rebuildPreviewMesh(getBuildPiece(selectedBuildPiece)); } },
    { label:"Single Frame", meta:"Single door opening", onClick: () => { selectedBuildPiece = "single_door_frame"; rebuildPreviewMesh(getBuildPiece(selectedBuildPiece)); } },
    { label:"Double Frame", meta:"Double door opening", onClick: () => { selectedBuildPiece = "double_door_frame"; rebuildPreviewMesh(getBuildPiece(selectedBuildPiece)); } },
    { label:"Single Door", meta:"Place in single frame", onClick: () => { selectedBuildPiece = "single_wood_door"; rebuildPreviewMesh(getBuildPiece(selectedBuildPiece)); } },
    { label:"Double Door", meta:"Place in double frame", onClick: () => { selectedBuildPiece = "double_wood_door"; rebuildPreviewMesh(getBuildPiece(selectedBuildPiece)); } }
  ]);
}

function toggleDoor(buildRoot) {
  if (!buildRoot || !buildRoot.userData.isDoor) return;
  buildRoot.userData.open = !buildRoot.userData.open;
  buildRoot.userData.targetAngle = buildRoot.userData.open ? (buildRoot.userData.frameType === "double" ? Math.PI * 0.5 : Math.PI * 0.85) : 0;
}

function updatePlacedBuilds(delta) {
  const target = getTargetedBuild();
  if (equippedTool === "hammer") setBuildHighlight(target);
  else clearBuildHighlight();

  if (buildHint) {
    if (equippedTool === "building_plan" && selectedBuildPiece) {
      const piece = getBuildPiece(selectedBuildPiece);
      buildHint.style.display = "block";
      buildHint.textContent = "Building Plan: " + (piece ? piece.name : "Wall");
    } else if (equippedTool === "hammer" && target && !target.userData.isDoor) {
      const tier = (target.userData.tier || "twig").toUpperCase();
      const health = target.userData.maxHealth || 120;
      buildHint.style.display = "block";
      buildHint.textContent = tier + " | " + (target.userData.stability || 52) + "% STABLE | " + health + " HP";
    } else {
      buildHint.style.display = "none";
    }
  }

  for (const build of placedBuilds) {
    const root = build.root;
    if (root.userData.isDoor) {
      root.rotation.z = THREE.MathUtils.lerp(root.rotation.z, root.userData.targetAngle || 0, delta * 6);
    }
  }
}

function updateVitals(delta) {
  player.hunger = Math.max(0, player.hunger - delta * 0.45);
  player.water = Math.max(0, player.water - delta * 0.7);

  if (player.hunger <= 0 || player.water <= 0) {
    player.health = Math.max(1, player.health - delta * 3.5);
  }
}

function updateDayNightCycle(nowMs) {
  const cycle = (nowMs * 0.001) / DAY_NIGHT_SECONDS;
  const sunPhase = cycle * Math.PI * 2;
  const daylight = THREE.MathUtils.clamp(Math.sin(sunPhase) * 0.5 + 0.5, 0.08, 1);

  sun.position.set(Math.cos(sunPhase) * 140, 30 + daylight * 120, Math.sin(sunPhase) * 140);
  sun.intensity = 0.15 + daylight * 1.15;
  hemi.intensity = 0.18 + daylight * 0.72;

  scene.background.copy(nightSkyColor).lerp(daySkyColor, daylight);
  scene.fog.color.copy(scene.background);
}

function isRainingAt(nowMs) {
  const cycleMs = 5 * 60 * 1000;
  const phaseMs = nowMs % cycleMs;
  const cycleIndex = Math.floor(nowMs / cycleMs);
  const shouldRainThisCycle = Math.sin(cycleIndex * 12.9898 + 4.123) > 0;
  return shouldRainThisCycle && phaseMs < 2 * 60 * 1000;
}

function updateBiomeAtmosphere(nowMs, delta) {
  const biome = getBiomeAt(player.pos.x, player.pos.z);
  const raining = biome !== "snow" && isRainingAt(nowMs);

  if (biome === "snow") {
    scene.fog.near = 36;
    scene.fog.far = 118;
  } else if (raining) {
    scene.fog.near = 55;
    scene.fog.far = 180;
  } else {
    scene.fog.near = 80;
    scene.fog.far = 260;
  }

  updateWeatherParticles(delta, biome, raining);
}

function drawWorldMap() {
  if (!mapCanvas) return;
  const ctx = mapCanvas.getContext("2d");
  const w = mapCanvas.width;
  const h = mapCanvas.height;
  const mapX = x => w * 0.5 + (x / WATER_INNER) * (w * 0.4);
  const mapY = z => h * 0.5 + (z / WATER_INNER) * (h * 0.4);

  ctx.clearRect(0, 0, w, h);
  ctx.fillStyle = "#17324c";
  ctx.fillRect(0, 0, w, h);

  const cell = 4;
  for (let px=0; px<w; px+=cell) {
    for (let py=0; py<h; py+=cell) {
      const worldX = ((px / w) - 0.5) * WATER_INNER * 2.05;
      const worldZ = ((py / h) - 0.5) * WATER_INNER * 2.05;
      const biome = getBiomeAt(worldX, worldZ);
      let color = "#17324c";
      if (biome === "beach") color = "#d5bf80";
      else if (biome === "grass") color = "#5d7f40";
      else if (biome === "snow") color = "#dde3e7";
      else if (biome === "desert") color = "#c9ad67";
      ctx.fillStyle = color;
      ctx.fillRect(px, py, cell, cell);
    }
  }

  ctx.strokeStyle = "rgba(30,50,25,0.4)";
  ctx.lineWidth = 1;
  for (let x=75; x<=w-75; x+=45) {
    ctx.beginPath();
    ctx.moveTo(x, 65);
    ctx.lineTo(x, h-65);
    ctx.stroke();
  }
  for (let y=65; y<=h-65; y+=38) {
    ctx.beginPath();
    ctx.moveTo(75, y);
    ctx.lineTo(w-75, y);
    ctx.stroke();
  }

  ctx.strokeStyle = "#3f78a8";
  ctx.lineWidth = 6;
  ctx.beginPath();
  ctx.moveTo(w * 0.74, h * 0.22);
  ctx.quadraticCurveTo(w * 0.7, h * 0.4, w * 0.78, h * 0.68);
  ctx.stroke();

  ctx.strokeStyle = "rgba(70,58,40,0.85)";
  ctx.lineWidth = 5;
  for (const road of worldLayout.roads) {
    ctx.beginPath();
    ctx.moveTo(mapX(road[0].x), mapY(road[0].z));
    for (let i=1; i<road.length; i++) ctx.lineTo(mapX(road[i].x), mapY(road[i].z));
    ctx.stroke();
  }

  ctx.fillStyle = "#222";
  ctx.font = "bold 22px sans-serif";
  ctx.fillText("Oxums", mapX(worldLayout.oxums.x - 6), mapY(worldLayout.oxums.z - 2));
  ctx.fillStyle = "#d74d3c";
  ctx.beginPath();
  ctx.arc(mapX(worldLayout.oxums.x), mapY(worldLayout.oxums.z), 7, 0, Math.PI*2);
  ctx.fill();

  ctx.fillStyle = "#fff";
  ctx.beginPath();
  ctx.arc(mapX(player.pos.x), mapY(player.pos.z), 6, 0, Math.PI*2);
  ctx.fill();
  ctx.fillStyle = "#111";
  ctx.font = "bold 12px sans-serif";
  ctx.fillText("YOU", mapX(player.pos.x) + 10, mapY(player.pos.z) - 10);

  ctx.fillStyle = "rgba(0,0,0,0.6)";
  ctx.font = "12px sans-serif";
  const labels = [
    ["SNOW", mapX(worldLayout.snowA.x - 20), mapY(worldLayout.snowA.z - 34)],
    ["GRASSLAND", mapX(0), mapY(0)],
    ["DESERT", mapX(worldLayout.desertA.x - 8), mapY(worldLayout.desertA.z - 22)],
    ["BEACH", mapX(112), mapY(126)]
  ];
  for (const [label, x, y] of labels) ctx.fillText(label, x, y);
}

/* drag & drop */
let dragging = false;
let dragSource = null;
let dragData = null;

function onAnySlotMouseDown(e) {
  const slotEl = e.currentTarget;
  const container = slotEl.dataset.container;
  const idx = parseInt(slotEl.dataset.index,10);

  if (container === "inventory" && !inventoryOpen && !lootOpen) return;
  if (container === "loot" && !lootOpen) return;

  let s;
  if (container === "inventory") s = slots[idx];
  else s = lootSlots[idx];

  if (!s.item) return;

  dragging = true;
  dragSource = { container, index:idx };
  dragData = { item:s.item, count:s.count };
  dragItemDiv.style.display = "block";
  dragItemDiv.textContent = itemName(s.item) + " x" + s.count;

  s.item = null;
  s.count = 0;
  refreshInventoryUI();
  refreshLootUI();
}

function onMouseMove(e) {
  if (!dragging) return;
  dragItemDiv.style.left = (e.clientX + 8) + "px";
  dragItemDiv.style.top  = (e.clientY + 8) + "px";
}

function placeIntoSlot(container, idx, data) {
  let arr = container === "inventory" ? slots : lootSlots;
  const s = arr[idx];

  if (!s.item) {
    s.item = data.item;
    s.count = data.count;
  } else if (s.item === data.item && container === "inventory" && s.count < MAX_STACK) {
    const space = MAX_STACK - s.count;
    const add = Math.min(space, data.count);
    s.count += add;
    const leftover = data.count - add;
    if (leftover > 0 && container === "inventory") {
      addItem(data.item, leftover);
    }
  } else {
    const tempItem = s.item;
    const tempCount = s.count;
    s.item = data.item;
    s.count = data.count;
    if (dragSource) {
      let srcArr = dragSource.container === "inventory" ? slots : lootSlots;
      const srcSlot = srcArr[dragSource.index];
      if (!srcSlot.item) {
        srcSlot.item = tempItem;
        srcSlot.count = tempCount;
      } else if (dragSource.container === "inventory" && srcSlot.item === tempItem && srcSlot.count < MAX_STACK) {
        const space = MAX_STACK - srcSlot.count;
        const add = Math.min(space, tempCount);
        srcSlot.count += add;
        const leftover = tempCount - add;
        if (leftover > 0) addItem(tempItem, leftover);
      } else {
        addItem(tempItem, tempCount);
      }
    } else {
      addItem(tempItem, tempCount);
    }
  }
}

function onMouseUp(e) {
  if (!dragging) return;
  dragging = false;
  dragItemDiv.style.display = "none";

  const target = document.elementFromPoint(e.clientX, e.clientY);
  if (!target) {
    if (dragSource) {
      let arr = dragSource.container === "inventory" ? slots : lootSlots;
      const s = arr[dragSource.index];
      if (!s.item) {
        s.item = dragData.item;
        s.count = dragData.count;
      } else if (dragSource.container === "inventory") {
        addItem(dragData.item, dragData.count);
      }
    }
    dragData = null;
    dragSource = null;
    refreshInventoryUI();
    refreshLootUI();
    return;
  }

  const slotEl = target.closest(".slot, .lootSlot");
  if (!slotEl) {
    if (dragSource) {
      let arr = dragSource.container === "inventory" ? slots : lootSlots;
      const s = arr[dragSource.index];
      if (!s.item) {
        s.item = dragData.item;
        s.count = dragData.count;
      } else if (dragSource.container === "inventory") {
        addItem(dragData.item, dragData.count);
      }
    }
    dragData = null;
    dragSource = null;
    refreshInventoryUI();
    refreshLootUI();
    return;
  }

  const container = slotEl.dataset.container;
  const idx = parseInt(slotEl.dataset.index,10);
  placeIntoSlot(container, idx, dragData);

  dragData = null;
  dragSource = null;
  refreshInventoryUI();
  refreshLootUI();
}

