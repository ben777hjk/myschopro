      addMesh(new THREE.BoxGeometry(0.22, 3.0, 0.18), mats.beam, 1.78, 1.5, 0);
      addMesh(new THREE.BoxGeometry(4.0, 0.2, 0.18), mats.beam, 0, 2.82, 0);
      addMesh(new THREE.BoxGeometry(4.95, 0.14, 0.16), mats.detail, 0, 1.5, 0, 0, 0, 0.76);
