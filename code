    roughness:0.4
  });

  const base = new THREE.Mesh(new THREE.BoxGeometry(1.35, 0.7, 1.0), woodMat);
  base.castShadow = true;
  base.receiveShadow = true;
  g.add(base);

  const lid = new THREE.Mesh(new THREE.BoxGeometry(1.45, 0.16, 1.08), trimMat);
  lid.position.y = 0.43;
  lid.castShadow = true;
  g.add(lid);

  const latch = new THREE.Mesh(new THREE.BoxGeometry(0.2, 0.18, 0.08), glowMat);
  latch.position.set(0, 0.2, 0.54);
  g.add(latch);

  const edgeGeo = new THREE.BoxGeometry(0.08, 0.82, 1.04);
  const edge1 = new THREE.Mesh(edgeGeo, trimMat);
  const edge2 = edge1.clone();
  edge1.position.x = -0.68;
  edge2.position.x = 0.68;
  g.add(edge1, edge2);

  const bandGeo = new THREE.BoxGeometry(1.22, 0.1, 0.08);
  const bandFront = new THREE.Mesh(bandGeo, trimMat);
  const bandBack = bandFront.clone();
  bandFront.position.set(0, 0.05, 0.5);
  bandBack.position.set(0, 0.05, -0.5);
  g.add(bandFront, bandBack);

  const feetGeo = new THREE.BoxGeometry(0.14, 0.12, 0.14);
  const footPositions = [
    [-0.55,-0.4,-0.35],
    [0.55,-0.4,-0.35],
    [-0.55,-0.4,0.35],
    [0.55,-0.4,0.35]
  ];
  for (const p of footPositions) {
    const foot = new THREE.Mesh(feetGeo, trimMat);
    foot.position.set(p[0], p[1], p[2]);
    g.add(foot);
  }

  return g;
}

