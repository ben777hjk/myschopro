          removeItem("wood", 50);
          applyTierToBuild(target, "wood");
        }
      }
    },
    {
      label:"Upgrade Stone",
      meta:"Heavy stone upgrade",
      onClick: () => {
        if (totalOf("stone") >= 60) {
          removeItem("stone", 60);
