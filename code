  }

  if (piece.id === "floor" || piece.id === "ceiling") {
    addMesh(new THREE.BoxGeometry(4, 0.36, 4), mats.panel, 0, 0.18, 0);
    for (const x of [-1.3, 0, 1.3]) addMesh(new THREE.BoxGeometry(0.16, 0.28, 3.8), mats.beam, x, 0.18, 0);
    for (const z of [-1.3, 1.3]) addMesh(new THREE.BoxGeometry(3.8, 0.28, 0.16), mats.beam, 0, 0.18, z);
    return { group, highlightMeshes };
  }

  if (isWallLike && tier === "twig") {
    const postPositions = isFrame ? [-1.78, -1.54, 1.54, 1.78] : [-1.62, -1.28, -0.96, -0.62, -0.28, 0.06, 0.38, 0.74, 1.08, 1.42, 1.7];
